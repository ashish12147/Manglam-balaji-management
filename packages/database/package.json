{
  "name": "@manglam/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PostgreSQL persistence, Prisma schema, migrations, and database client for Manglam Balaji Society.",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./credential-hasher": {
      "types": "./dist/security/credential-hasher.d.ts",
      "import": "./dist/security/credential-hasher.js"
    },
    "./generated": {
      "types": "./dist/generated/prisma/client.d.ts",
      "import": "./dist/generated/prisma/client.js"
    }
  },
  "files": [
    "dist",
    "prisma/schema.prisma",
    "prisma/migrations"
  ],
  "scripts": {
    "build": "pnpm generate && tsc -p tsconfig.build.json",
    "clean": "rimraf dist src/generated coverage",
    "format": "prisma format",
    "generate": "prisma generate",
    "lint": "pnpm generate && tsc -p tsconfig.json --noEmit",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:status": "prisma migrate status",
    "seed": "prisma db seed",
    "provision:admin": "tsx scripts/provision-admin.ts",
    "test": "pnpm generate && vitest run --exclude tests/postgresql.integration.test.ts",
    "test:coverage": "pnpm test",
    "test:integration": "pnpm generate && vitest run tests/postgresql.integration.test.ts",
    "typecheck": "pnpm generate && tsc -p tsconfig.json --noEmit",
    "validate": "prisma validate && vitest run tests/schema-contract.test.ts"
  },
  "dependencies": {
    "@manglam/permissions": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.8.0",
    "rimraf": "6.1.2",
    "tsx": "4.23.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
