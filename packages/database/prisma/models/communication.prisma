model Notice {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId               String                  @map("society_id") @db.Uuid
  title                   String                  @db.VarChar(200)
  body                    String                  @db.Text
  category                NoticeCategory
  priority                NoticePriority          @default(NORMAL)
  status                  NoticeStatus            @default(DRAFT)
  publishAt               DateTime?               @map("publish_at") @db.Timestamptz(6)
  publishedAt             DateTime?               @map("published_at") @db.Timestamptz(6)
  expiresAt               DateTime?               @map("expires_at") @db.Timestamptz(6)
  createdByUserId         String                  @map("created_by_user_id") @db.Uuid
  publishedByUserId       String?                 @map("published_by_user_id") @db.Uuid
  requiresAcknowledgement Boolean                 @default(false) @map("requires_acknowledgement")
  audienceFrozenAt        DateTime?               @map("audience_frozen_at") @db.Timestamptz(6)
  version                 Int                     @default(1)
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  audiences               NoticeAudience[]
  recipients              NoticeRecipient[]
  attachments             NoticeAttachment[]
  reads                   NoticeRead[]
  acknowledgements        NoticeAcknowledgement[]

  @@unique([societyId, id], map: "notices_society_id_id_key")
  @@index([societyId, status, publishedAt(sort: Desc)], map: "notices_society_status_published_idx")
  @@index([priority, status, expiresAt], map: "notices_priority_status_expires_idx")
  @@map("notices")
}

model NoticeAudience {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId String       @map("society_id") @db.Uuid
  noticeId  String       @map("notice_id") @db.Uuid
  type      AudienceType
  roleId    String?      @map("role_id") @db.Uuid
  blockId   String?      @map("block_id") @db.Uuid
  flatId    String?      @map("flat_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  notice    Notice       @relation(fields: [noticeId], references: [id], onDelete: Restrict)
  role      Role?        @relation(fields: [roleId], references: [id], onDelete: Restrict)
  block     Block?       @relation(fields: [blockId], references: [id], onDelete: Restrict)
  flat      Flat?        @relation(fields: [flatId], references: [id], onDelete: Restrict)

  @@unique([societyId, id], map: "notice_audiences_society_id_id_key")
  @@index([noticeId, type], map: "notice_audiences_notice_type_idx")
  @@map("notice_audiences")
}

model NoticeRecipient {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId    String   @map("society_id") @db.Uuid
  noticeId     String   @map("notice_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  membershipId String?  @map("membership_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  notice       Notice   @relation(fields: [noticeId], references: [id], onDelete: Restrict)
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([noticeId, userId], map: "notice_recipients_notice_user_key")
  @@unique([societyId, id], map: "notice_recipients_society_id_id_key")
  @@index([userId, createdAt(sort: Desc)], map: "notice_recipients_user_created_idx")
  @@map("notice_recipients")
}

model NoticeAttachment {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId String     @map("society_id") @db.Uuid
  noticeId  String     @map("notice_id") @db.Uuid
  fileId    String     @map("file_id") @db.Uuid
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  notice    Notice     @relation(fields: [noticeId], references: [id], onDelete: Restrict)
  file      FileUpload @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([noticeId, fileId], map: "notice_attachments_notice_file_key")
  @@unique([societyId, id], map: "notice_attachments_society_id_id_key")
  @@map("notice_attachments")
}

model NoticeRead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId String   @map("society_id") @db.Uuid
  noticeId  String   @map("notice_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @default(now()) @map("read_at") @db.Timestamptz(6)
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Restrict)
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([noticeId, userId], map: "notice_reads_notice_user_key")
  @@unique([societyId, id], map: "notice_reads_society_id_id_key")
  @@index([userId, readAt(sort: Desc)], map: "notice_reads_user_read_idx")
  @@map("notice_reads")
}

model NoticeAcknowledgement {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId      String   @map("society_id") @db.Uuid
  noticeId       String   @map("notice_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at") @db.Timestamptz(6)
  notice         Notice   @relation(fields: [noticeId], references: [id], onDelete: Restrict)
  user           User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([noticeId, userId], map: "notice_acknowledgements_notice_user_key")
  @@unique([societyId, id], map: "notice_acknowledgements_society_id_id_key")
  @@index([userId, acknowledgedAt(sort: Desc)], map: "notice_acknowledgements_user_ack_idx")
  @@map("notice_acknowledgements")
}

model ComplaintCategory {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId   String       @map("society_id") @db.Uuid
  code        String       @db.VarChar(64)
  name        String       @db.VarChar(120)
  description String?      @db.VarChar(500)
  slaHours    Int?         @map("sla_hours")
  status      RecordStatus @default(ACTIVE)
  sortOrder   Int          @default(0) @map("sort_order")
  version     Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  society     Society      @relation(fields: [societyId], references: [id], onDelete: Restrict)
  complaints  Complaint[]

  @@unique([societyId, code], map: "complaint_categories_society_code_key")
  @@unique([societyId, id], map: "complaint_categories_society_id_id_key")
  @@index([societyId, status, sortOrder], map: "complaint_categories_society_status_sort_idx")
  @@map("complaint_categories")
}

model Complaint {
  id                    String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId             String                       @map("society_id") @db.Uuid
  flatId                String                       @map("flat_id") @db.Uuid
  categoryId            String                       @map("category_id") @db.Uuid
  createdByUserId       String                       @map("created_by_user_id") @db.Uuid
  createdByMembershipId String                       @map("created_by_membership_id") @db.Uuid
  subject               String                       @db.VarChar(200)
  description           String                       @db.Text
  priority              ComplaintPriority            @default(NORMAL)
  status                ComplaintStatus              @default(OPEN)
  assignedToUserId      String?                      @map("assigned_to_user_id") @db.Uuid
  resolutionNotes       String?                      @map("resolution_notes") @db.Text
  resolvedAt            DateTime?                    @map("resolved_at") @db.Timestamptz(6)
  closedAt              DateTime?                    @map("closed_at") @db.Timestamptz(6)
  reopenCount           Int                          @default(0) @map("reopen_count")
  version               Int                          @default(1)
  createdAt             DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  flat                  Flat                         @relation(fields: [flatId], references: [id], onDelete: Restrict)
  category              ComplaintCategory            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  attachments           ComplaintAttachment[]
  comments              ComplaintComment[]
  internalNotes         ComplaintInternalNote[]
  statusHistory         ComplaintStatusHistory[]
  assignmentHistory     ComplaintAssignmentHistory[]

  @@unique([societyId, id], map: "complaints_society_id_id_key")
  @@index([status, priority, createdAt], map: "complaints_status_priority_created_idx")
  @@index([flatId, createdAt(sort: Desc)], map: "complaints_flat_created_idx")
  @@index([assignedToUserId, status], map: "complaints_assignee_status_idx")
  @@map("complaints")
}

model ComplaintAttachment {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId         String     @map("society_id") @db.Uuid
  complaintId       String     @map("complaint_id") @db.Uuid
  fileId            String     @map("file_id") @db.Uuid
  uploadedByUserId  String     @map("uploaded_by_user_id") @db.Uuid
  visibleToResident Boolean    @default(true) @map("visible_to_resident")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  complaint         Complaint  @relation(fields: [complaintId], references: [id], onDelete: Restrict)
  file              FileUpload @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([complaintId, fileId], map: "complaint_attachments_complaint_file_key")
  @@unique([societyId, id], map: "complaint_attachments_society_id_id_key")
  @@map("complaint_attachments")
}

model ComplaintComment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId    String    @map("society_id") @db.Uuid
  complaintId  String    @map("complaint_id") @db.Uuid
  authorUserId String    @map("author_user_id") @db.Uuid
  body         String    @db.Text
  editedAt     DateTime? @map("edited_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Restrict)

  @@unique([societyId, id], map: "complaint_comments_society_id_id_key")
  @@index([complaintId, createdAt], map: "complaint_comments_complaint_created_idx")
  @@map("complaint_comments")
}

model ComplaintInternalNote {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId    String    @map("society_id") @db.Uuid
  complaintId  String    @map("complaint_id") @db.Uuid
  authorUserId String    @map("author_user_id") @db.Uuid
  body         String    @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Restrict)

  @@unique([societyId, id], map: "complaint_internal_notes_society_id_id_key")
  @@index([complaintId, createdAt], map: "complaint_internal_notes_complaint_created_idx")
  @@map("complaint_internal_notes")
}

model ComplaintStatusHistory {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId       String           @map("society_id") @db.Uuid
  complaintId     String           @map("complaint_id") @db.Uuid
  sequence        Int
  fromStatus      ComplaintStatus? @map("from_status")
  toStatus        ComplaintStatus  @map("to_status")
  actorUserId     String           @map("actor_user_id") @db.Uuid
  reason          String?          @db.VarChar(500)
  resolutionNotes String?          @map("resolution_notes") @db.Text
  correlationId   String           @map("correlation_id") @db.Uuid
  occurredAt      DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(6)
  complaint       Complaint        @relation(fields: [complaintId], references: [id], onDelete: Restrict)

  @@unique([complaintId, sequence], map: "complaint_status_history_complaint_sequence_key")
  @@unique([societyId, id], map: "complaint_status_history_society_id_id_key")
  @@index([complaintId, occurredAt], map: "complaint_status_history_complaint_occurred_idx")
  @@map("complaint_status_history")
}

model ComplaintAssignmentHistory {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId          String    @map("society_id") @db.Uuid
  complaintId        String    @map("complaint_id") @db.Uuid
  sequence           Int
  fromAssigneeUserId String?   @map("from_assignee_user_id") @db.Uuid
  toAssigneeUserId   String?   @map("to_assignee_user_id") @db.Uuid
  actorUserId        String    @map("actor_user_id") @db.Uuid
  reason             String?   @db.VarChar(500)
  correlationId      String    @map("correlation_id") @db.Uuid
  occurredAt         DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  complaint          Complaint @relation(fields: [complaintId], references: [id], onDelete: Restrict)

  @@unique([complaintId, sequence], map: "complaint_assignment_history_complaint_sequence_key")
  @@unique([societyId, id], map: "complaint_assignment_history_society_id_id_key")
  @@index([complaintId, occurredAt], map: "complaint_assignment_history_complaint_occurred_idx")
  @@map("complaint_assignment_history")
}
