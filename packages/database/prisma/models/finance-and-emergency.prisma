model MaintenanceChargeBatch {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId       String              @map("society_id") @db.Uuid
  code            String              @db.VarChar(80)
  periodStart     DateTime            @map("period_start") @db.Date
  periodEnd       DateTime            @map("period_end") @db.Date
  dueDate         DateTime            @map("due_date") @db.Date
  description     String              @db.VarChar(240)
  status          ChargeBatchStatus   @default(DRAFT)
  createdByUserId String              @map("created_by_user_id") @db.Uuid
  postedByUserId  String?             @map("posted_by_user_id") @db.Uuid
  postedAt        DateTime?           @map("posted_at") @db.Timestamptz(6)
  cancelledAt     DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancelReason    String?             @map("cancel_reason") @db.VarChar(500)
  version         Int                 @default(1)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  society         Society             @relation(fields: [societyId], references: [id], onDelete: Restrict)
  charges         MaintenanceCharge[]

  @@unique([societyId, code], map: "maintenance_batches_society_code_key")
  @@unique([societyId, id], map: "maintenance_batches_society_id_id_key")
  @@index([societyId, status, periodStart(sort: Desc)], map: "maintenance_batches_status_period_idx")
  @@map("maintenance_charge_batches")
}

model MaintenanceCharge {
  id               String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId        String                        @map("society_id") @db.Uuid
  batchId          String                        @map("batch_id") @db.Uuid
  flatId           String                        @map("flat_id") @db.Uuid
  periodStart      DateTime                      @map("period_start") @db.Date
  periodEnd        DateTime                      @map("period_end") @db.Date
  dueDate          DateTime                      @map("due_date") @db.Date
  baseAmount       Decimal                       @map("base_amount") @db.Decimal(12, 2)
  previousBalance  Decimal                       @default(0) @map("previous_balance") @db.Decimal(12, 2)
  lateCharge       Decimal                       @default(0) @map("late_charge") @db.Decimal(12, 2)
  adjustmentAmount Decimal                       @default(0) @map("adjustment_amount") @db.Decimal(12, 2)
  totalAmount      Decimal                       @map("total_amount") @db.Decimal(12, 2)
  paidAmount       Decimal                       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  currency         String                        @default("INR") @db.Char(3)
  status           MaintenanceDueStatus          @default(UNPAID)
  version          Int                           @default(1)
  createdAt        DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  batch            MaintenanceChargeBatch        @relation(fields: [batchId], references: [id], onDelete: Restrict)
  flat             Flat                          @relation(fields: [flatId], references: [id], onDelete: Restrict)
  adjustments      MaintenanceChargeAdjustment[]
  allocations      PaymentAllocation[]

  @@unique([flatId, periodStart], map: "maintenance_charges_flat_period_key")
  @@unique([societyId, id], map: "maintenance_charges_society_id_id_key")
  @@index([flatId, dueDate], map: "maintenance_charges_flat_due_date_idx")
  @@index([status, dueDate], map: "maintenance_charges_status_due_date_idx")
  @@map("maintenance_charges")
}

model MaintenanceChargeAdjustment {
  id                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId              String               @map("society_id") @db.Uuid
  chargeId               String               @map("charge_id") @db.Uuid
  type                   ChargeAdjustmentType
  amount                 Decimal              @db.Decimal(12, 2)
  reason                 String               @db.VarChar(500)
  actorUserId            String               @map("actor_user_id") @db.Uuid
  reversalOfAdjustmentId String?              @map("reversal_of_adjustment_id") @db.Uuid
  correlationId          String               @map("correlation_id") @db.Uuid
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  charge                 MaintenanceCharge    @relation(fields: [chargeId], references: [id], onDelete: Restrict)

  @@unique([societyId, id], map: "maintenance_adjustments_society_id_id_key")
  @@index([chargeId, createdAt], map: "maintenance_adjustments_charge_created_idx")
  @@map("maintenance_charge_adjustments")
}

model Payment {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId             String              @map("society_id") @db.Uuid
  flatId                String              @map("flat_id") @db.Uuid
  method                PaymentMethod
  status                PaymentStatus       @default(PENDING_VERIFICATION)
  amount                Decimal             @db.Decimal(12, 2)
  currency              String              @default("INR") @db.Char(3)
  reference             String?             @db.VarChar(160)
  providerTransactionId String?             @map("provider_transaction_id") @db.VarChar(160)
  receivedAt            DateTime            @map("received_at") @db.Timestamptz(6)
  recordedByUserId      String              @map("recorded_by_user_id") @db.Uuid
  verifiedByUserId      String?             @map("verified_by_user_id") @db.Uuid
  verifiedAt            DateTime?           @map("verified_at") @db.Timestamptz(6)
  notes                 String?             @db.VarChar(500)
  version               Int                 @default(1)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  flat                  Flat                @relation(fields: [flatId], references: [id], onDelete: Restrict)
  allocations           PaymentAllocation[]
  reversals             PaymentReversal[]
  receipt               Receipt?

  @@unique([societyId, id], map: "payments_society_id_id_key")
  @@index([flatId, receivedAt(sort: Desc)], map: "payments_flat_received_idx")
  @@index([status, receivedAt(sort: Desc)], map: "payments_status_received_idx")
  @@index([reference], map: "payments_reference_idx")
  @@map("payments")
}

model PaymentAllocation {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId   String            @map("society_id") @db.Uuid
  flatId      String            @map("flat_id") @db.Uuid
  paymentId   String            @map("payment_id") @db.Uuid
  chargeId    String            @map("charge_id") @db.Uuid
  amount      Decimal           @db.Decimal(12, 2)
  allocatedAt DateTime          @default(now()) @map("allocated_at") @db.Timestamptz(6)
  payment     Payment           @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  charge      MaintenanceCharge @relation(fields: [chargeId], references: [id], onDelete: Restrict)

  @@unique([paymentId, chargeId], map: "payment_allocations_payment_charge_key")
  @@unique([societyId, id], map: "payment_allocations_society_id_id_key")
  @@index([chargeId], map: "payment_allocations_charge_id_idx")
  @@map("payment_allocations")
}

model PaymentReversal {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId      String   @map("society_id") @db.Uuid
  paymentId      String   @map("payment_id") @db.Uuid
  amount         Decimal  @db.Decimal(12, 2)
  reason         String   @db.VarChar(500)
  actorUserId    String   @map("actor_user_id") @db.Uuid
  idempotencyKey String   @map("idempotency_key") @db.VarChar(160)
  correlationId  String   @map("correlation_id") @db.Uuid
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@unique([societyId, idempotencyKey], map: "payment_reversals_society_idempotency_key")
  @@unique([societyId, id], map: "payment_reversals_society_id_id_key")
  @@index([paymentId, occurredAt], map: "payment_reversals_payment_occurred_idx")
  @@map("payment_reversals")
}

model Receipt {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId      String         @map("society_id") @db.Uuid
  paymentId      String         @unique(map: "receipts_payment_id_key") @map("payment_id") @db.Uuid
  number         String         @db.VarChar(80)
  status         ReceiptStatus  @default(ISSUED)
  totalAmount    Decimal        @map("total_amount") @db.Decimal(12, 2)
  currency       String         @default("INR") @db.Char(3)
  issuedAt       DateTime       @default(now()) @map("issued_at") @db.Timestamptz(6)
  issuedByUserId String         @map("issued_by_user_id") @db.Uuid
  voidedAt       DateTime?      @map("voided_at") @db.Timestamptz(6)
  voidedByUserId String?        @map("voided_by_user_id") @db.Uuid
  voidReason     String?        @map("void_reason") @db.VarChar(500)
  fileId         String?        @map("file_id") @db.Uuid
  version        Int            @default(1)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  payment        Payment        @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  file           FileUpload?    @relation("ReceiptFile", fields: [fileId], references: [id], onDelete: Restrict)
  events         ReceiptEvent[]

  @@unique([societyId, number], map: "receipts_society_number_key")
  @@unique([societyId, id], map: "receipts_society_id_id_key")
  @@index([issuedAt(sort: Desc)], map: "receipts_issued_at_idx")
  @@map("receipts")
}

model ReceiptEvent {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId     String           @map("society_id") @db.Uuid
  receiptId     String           @map("receipt_id") @db.Uuid
  sequence      Int
  eventType     ReceiptEventType @map("event_type")
  actorUserId   String           @map("actor_user_id") @db.Uuid
  reason        String?          @db.VarChar(500)
  correlationId String           @map("correlation_id") @db.Uuid
  metadata      Json?            @db.JsonB
  occurredAt    DateTime         @default(now()) @map("occurred_at") @db.Timestamptz(6)
  receipt       Receipt          @relation(fields: [receiptId], references: [id], onDelete: Restrict)

  @@unique([receiptId, sequence], map: "receipt_events_receipt_sequence_key")
  @@unique([societyId, id], map: "receipt_events_society_id_id_key")
  @@index([receiptId, occurredAt], map: "receipt_events_receipt_occurred_idx")
  @@map("receipt_events")
}

model DocumentSequence {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId    String   @map("society_id") @db.Uuid
  kind         String   @db.VarChar(64)
  prefix       String   @db.VarChar(24)
  year         Int
  currentValue BigInt   @default(0) @map("current_value")
  version      Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  society      Society  @relation(fields: [societyId], references: [id], onDelete: Restrict)

  @@unique([societyId, kind, year], map: "document_sequences_society_kind_year_key")
  @@unique([societyId, id], map: "document_sequences_society_id_id_key")
  @@map("document_sequences")
}

model EmergencyAlert {
  id                        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId                 String            @map("society_id") @db.Uuid
  flatId                    String            @map("flat_id") @db.Uuid
  createdByUserId           String            @map("created_by_user_id") @db.Uuid
  category                  EmergencyCategory
  status                    EmergencyStatus   @default(ACTIVE)
  description               String?           @db.VarChar(500)
  acknowledgedByGuardId     String?           @map("acknowledged_by_guard_id") @db.Uuid
  guardAcknowledgedAt       DateTime?         @map("guard_acknowledged_at") @db.Timestamptz(6)
  acknowledgedByAdminUserId String?           @map("acknowledged_by_admin_user_id") @db.Uuid
  adminAcknowledgedAt       DateTime?         @map("admin_acknowledged_at") @db.Timestamptz(6)
  respondingAt              DateTime?         @map("responding_at") @db.Timestamptz(6)
  resolvedAt                DateTime?         @map("resolved_at") @db.Timestamptz(6)
  resolvedByUserId          String?           @map("resolved_by_user_id") @db.Uuid
  resolution                String?           @db.Text
  version                   Int               @default(1)
  createdAt                 DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  flat                      Flat              @relation(fields: [flatId], references: [id], onDelete: Restrict)
  events                    EmergencyEvent[]

  @@unique([societyId, id], map: "emergency_alerts_society_id_id_key")
  @@index([societyId, status, createdAt(sort: Desc)], map: "emergency_alerts_society_status_created_idx")
  @@index([flatId, createdAt(sort: Desc)], map: "emergency_alerts_flat_created_idx")
  @@map("emergency_alerts")
}

model EmergencyEvent {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  societyId           String             @map("society_id") @db.Uuid
  alertId             String             @map("alert_id") @db.Uuid
  sequence            Int
  eventType           EmergencyEventType @map("event_type")
  previousStatus      EmergencyStatus?   @map("previous_status")
  newStatus           EmergencyStatus?   @map("new_status")
  actorUserId         String?            @map("actor_user_id") @db.Uuid
  actorGuardProfileId String?            @map("actor_guard_profile_id") @db.Uuid
  details             String?            @db.VarChar(1000)
  correlationId       String             @map("correlation_id") @db.Uuid
  metadata            Json?              @db.JsonB
  occurredAt          DateTime           @default(now()) @map("occurred_at") @db.Timestamptz(6)
  alert               EmergencyAlert     @relation(fields: [alertId], references: [id], onDelete: Restrict)

  @@unique([alertId, sequence], map: "emergency_events_alert_sequence_key")
  @@unique([societyId, id], map: "emergency_events_society_id_id_key")
  @@index([alertId, occurredAt], map: "emergency_events_alert_occurred_idx")
  @@map("emergency_events")
}
