# Runtime
APP_ENV=development
NODE_ENV=development
APP_VERSION=0.1.0
PORT=4000
LOG_LEVEL=info
API_PREFIX=/api/v1
PUBLIC_API_URL=http://127.0.0.1:4000/api/v1
ADMIN_WEB_URL=http://127.0.0.1:3000
CORS_ORIGINS=http://127.0.0.1:3000
TRUST_PROXY=false

# Database and Redis
DATABASE_URL=postgresql://manglam:manglam@127.0.0.1:5432/manglam_balaji
DIRECT_DATABASE_URL=postgresql://manglam:manglam@127.0.0.1:5432/manglam_balaji
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=5000
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PREFIX=manglam:development

# Authentication - generate unique values outside development
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=manglam-balaji
JWT_AUDIENCE=manglam-balaji-clients
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_SECONDS=2592000
REFRESH_TOKEN_PEPPER=replace-with-at-least-32-random-characters
APP_PIN_PEPPER=replace-with-at-least-32-random-characters
COOKIE_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_KEY=replace-with-32-byte-base64-key

# OTP
OTP_PROVIDER=development
OTP_HMAC_SECRET=replace-with-at-least-32-random-characters
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_SENDER_ID=
OTP_TEMPLATE_ID=

# Storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=ap-south-1
S3_BUCKET=manglam-development
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KMS_KEY_ID=
SIGNED_URL_TTL_SECONDS=60
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Jobs, realtime, and visitor rules
QUEUE_PREFIX=manglam-development
WORKER_CONCURRENCY=5
JOB_ATTEMPTS=5
JOB_BACKOFF_MS=1000
IDEMPOTENCY_TTL_SECONDS=86400
SOCKET_IO_PATH=/socket.io
WS_ORIGINS=http://127.0.0.1:3000
VISITOR_CODE_HMAC_SECRET=replace-with-at-least-32-random-characters
VISITOR_APPROVAL_TIMEOUT_SECONDS=120
LONG_VISIT_THRESHOLD_MINUTES=720

# Notifications and observability
PUSH_PROVIDER=development
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
EXPO_ACCESS_TOKEN=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Public client configuration - never place secrets here
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000/api/v1
NEXT_PUBLIC_WS_URL=http://127.0.0.1:4000
EXPO_PUBLIC_API_URL=http://127.0.0.1:4000/api/v1
EXPO_PUBLIC_WS_URL=http://127.0.0.1:4000
EXPO_PUBLIC_APP_ENV=development
EAS_PROJECT_ID=
